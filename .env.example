# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Quote if secret contains + or = (Supabase Legacy JWT Secret often does)
SUPABASE_JWT_SECRET=

# Database URL (optional if using direct Postgres connection)
DATABASE_URL=

# FastAPI settings
API_HOST=0.0.0.0
API_PORT=8000

# RAG embeddings (for vector search - OpenAI text-embedding-3-small)
# OPENAI_API_KEY= or EMBEDDING_API_KEY=

# Allowed MCP origins (comma-separated)
MCP_ALLOWED_ORIGINS=localhost,127.0.0.1

# Ollama (local Llama) - available as "default" model to all users
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=llama3.2  # optional; otherwise first Llama found

# WhatsApp Business MCP (mcp-servers/whatsapp_business) - from Meta Developer Console
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# LinkedIn MCP (mcp-servers/linkedin) - from LiGo or LinkedIn OAuth
# LINKEDIN_ACCESS_TOKEN=

# Next.js - for client-side Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:8000
